# Spotify app credentials (from https://developer.spotify.com/dashboard).
# Copy this file to ".env" and fill in your real values. Do NOT commit .env.
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# The exact device name to pin playback to (from Spotify Connect).
SPOTIFY_TARGET_DEVICE=My Speaker

# Optional:
# SPOTIFY_TARGET_DEVICE_ID=
# SPOTIFY_FALLBACK_URI=spotify:playlist:37i9dQZF1DXcBWIGoYBM5M
# SPOTIFY_POLL_SECONDS=10
